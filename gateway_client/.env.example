# --- Cloud Dashboard Connection ---
DJANGO_SERVER_URL=http://your-server-ip:8000
GATEWAY_API_KEY=your-uuid-api-key-here

# --- Hardware Attestation ---
# Leave blank to auto-detect on Raspberry Pi
GATEWAY_MAC=
GATEWAY_HW_SERIAL=

# --- Local Service Configuration ---
# Flask port for biometric device pushing
FLASK_PORT=8080

# Local SQLite buffer path
DATABASE_PATH=local_buffer.db

# Security: PBKDF2 Iterations (MUST match Cloud Dashboard)
PBKDF2_ITERATIONS=600000
