# --- Django Core Settings ---
SECRET_KEY=your-django-insecure-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,*
DATABASE_URL=sqlite:///db.sqlite3
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# --- Security Configuration ---
# PBKDF2 Iterations used for session key derivation (Match with Gateway Client)
PBKDF2_ITERATIONS=600000

# --- AWS SES (Email) Configuration ---
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_S3_REGION_NAME=ap-south-1
AWS_SES_FROM_EMAIL=your-verified-email@domain.com
EMAIL_BACKEND=django_ses.SESBackend

# --- Celery & Redis ---
# Default assumes Redis is running on localhost
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# --- AI Analytics (Ollama) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# --- Test & Simulation Configuration (PII/IP Redaction) ---
# Used by tests_and_simulations/ scripts
TEST_SERVER_URL=http://127.0.0.1:8000
GATEWAY_MAC=e4:5f:01:68:8a:a5
GATEWAY_API_KEY=c8101bf9-f38e-41cb-86f4-9e033ecbb4e4
GATEWAY_HW_SERIAL=10000000e32ea22b
BIOMETRIC_MACHINE_IP=192.168.1.50
